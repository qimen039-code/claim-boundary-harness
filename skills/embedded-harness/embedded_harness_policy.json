    "profile_rule": "Always compute the full routing decision internally. Keep R0-R5 labels silent by default and expose only fields that change execution path, cost, permission, memory, conversation-linking, external search, or claim behavior. Expand only when governance, public/private, projectization, R4/R5, memory write, conversation-link, strong claim, or debug triggers require it.",
    "compact_runtime": {
      "purpose": "default low-cost runtime receipt for ordinary nontrivial tasks and single-user local agents",
      "fields": [
        "task_type",
        "risk_level",
        "required_gates",
        "memory_mode",
        "memory_lane",
        "external_need",
        "claim_risk",
        "human_confirmation_need",
        "link_intent"
      ],
      "expand_when": [
        "public_or_private_audience",
        "semantic_ambiguity_present",
        "framework_or_adapter_or_project_memory_surface",
        "memory_write_or_update",
        "projectization_candidate",
        "debug_requested"
      ]
    },
    "extended_governance": {
      "purpose": "expanded receipt for framework rules, public repositories, adapters, project memory, conversation memory, projectization, archive, persona, and cross-boundary governance",
      "fields": [
        "task_type",
        "target_surface",
        "audience",
        "project_lane",
        "risk_level",
        "semantic_ambiguity",
        "module_need",
        "memory_need",
        "memory_mode",
        "memory_lane",
        "record_intent",
        "external_need",
        "claim_risk",
        "projectization_decision",
        "conversation_memory_decision",
        "link_intent",
        "required_gates"
      ]
    },
    "debug_receipt": {
      "purpose": "full diagnostic receipt for router development and misroute debugging",
      "fields": [
        "full_routing_receipt",
        "triggered_risks",
        "matched_risk_triggers",
        "negated_risk_triggers",
        "classification_confidence",
        "profile_reason"
      ]
    },
    "debug_triggers": [
      "debug receipt",
      "full receipt",
      "route debug",
      "routing debug",
      "调试回执",
      "完整回执",
      "路由调试"
    ]
  },
  "cost_control_contract": {
    "principle": "Maximum leverage, minimum active context.",
    "action_relevant_rule": "Only emit or load a field by default if it can change the next action. Otherwise keep it in docs, archive meta, debug receipt, or audit logs.",
    "classification_visibility_rule": "R0-R5 classification always runs internally. User-facing replies and prompt-stage context stay silent unless classification changes execution path, cost, permission, memory, external search, or claim boundary. Debug or audit requests expose the full receipt.",
    "routing_field_budget": {
      "R0": "no explicit receipt; microkernel only",
      "R1_R2": "usually implicit; compact_runtime only when an action-changing gate appears",
      "R3_R4": "compact_runtime plus triggered fields only; do not display risk labels unless needed for boundary explanation",
      "R5_or_boundary_sensitive": "extended_governance",
      "debug_or_audit": "debug_receipt"
    },
    "delta_receipt_rule": "After the initial receipt, re-evaluation should emit changed fields only unless full debug is requested.",
    "active_context_ceiling": {
      "max_meta_indexes": 1,
      "max_category_indexes": 1,
      "max_payload_records": 2,
      "default_full_history_scan": false
    }
  },
  "memory_routing_contract": {
    "mandatory_for_nontrivial_tasks": true,
    "purpose": "decide whether memory should be read, written, updated, or skipped before opening memory payloads",
    "default_rule": "Ordinary chat and projectless small fixes do not write memory unless the user explicitly asks, an error is recurring/reusable, a conversation checkpoint is needed, or projectization drift is detected.",
    "explicit_record_rule": "If the user says to record this error/problem/mistake or asks for self-reflection matrix recording, route to the self-reflection matrix or common error corpus according to severity.",
    "common_error_rule": "Small but recurring execution mistakes should enter common_error_corpus as lightweight CE error-and-solution records. A CE record must include the mistake, cause, applied solution, prevention rule, validation, and evidence; only high-impact, repeated, or user-explicit incidents upgrade to paired ERR/SOL records.",
    "conversation_memory_rule": "Projectless long-running conversations may create a current_conversation lane when the user explicitly asks for a checkpoint or when durable conversation signals cross the threshold. If an ACTIVE current_conversation lane already exists, durable decisions, reusable errors, memory schema changes, open-loop changes, or governance/routing fixes should route to memory_mode=update and memory_lane=current_conversation even when the same conversation has become project-shaped. This lane is isolated by conversation/thread id, follows meta-first retrieval, and may be read by other conversations only through explicit reference. Cross-conversation writes require explicit user instruction.",
    "source_monitoring_schema_rule": "Reusable memory capsules should preserve source_tag, belief_status, structured confidence, derived_from, source_monitoring, lifecycle, and belief_trace_summary. Optional numeric scores are adapter metadata and must not replace confidence basis or provenance.",
    "retrieval_result_rule": "Reusable memory retrieval results must include source_tag, derived_from, belief_status, confidence, and score_method with the selected text. If no numeric score is computed, use score_method=none and omit score.",
    "projectization_rule": "If projectless work accumulates durable files, versioning, repository/docs, tests, adapters, releases, or repeated architecture decisions, mark emergent_project_candidate and ask or state the lane assumption before durable memory writes.",
    "common_error_record_shape": [
      "ce_id",
      "class",
      "status",
      "surface",
      "symptom",
      "cause",
      "solution_applied",
      "prevention",
      "validation",
      "upgrade_to_err_sol_when",
      "evidence",
      "last_reviewed"
    ]
  },
  "global_archive_contract": {
    "mode": "optional_cold_index",
    "default_lookup_rule": "Use active project or conversation lane first. Read the global archive only when the user asks for archive lookup, the active lane has no relevant record, or a lane is being sealed or snapshotted.",
    "allowed_operations": [
      "ARCHIVE_MOVE",
      "ARCHIVE_COPY",
      "ARCHIVE_SUMMARY_CAPSULE"
    ],
    "default_operations": [
      "ARCHIVE_MOVE",
      "ARCHIVE_COPY"
    ],
    "summary_capsule_rule": "ARCHIVE_SUMMARY_CAPSULE requires explicit compression, migration, de-identification, public-release, or storage-reduction intent. Do not delete the source unless separately confirmed.",
    "hard_rules": [
      "do_not_regenerate_archived_memory_content_by_default",
      "move_or_copy_before_editing_archive_indexes",
      "preserve_source_ref_source_lane_source_path_archive_path_timestamp_operation_type_checksum_when_practical",
      "source_deletion_is_R5"
    ]
  },
