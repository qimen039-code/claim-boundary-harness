{
  "schema": "cbh.deployment_profiles.v1",
  "rule": "Deploy a named runtime profile. Do not copy the repository wholesale.",
  "profiles": {
    "workbuddy-hook-minimal": {
      "required_predeployment_read": "docs/agent-deployment-map.md",
      "description": "WorkBuddy advisory prompt routing plus an optional stateless correction bridge that remains disabled until the host protocol is verified.",
      "runtime_mode": "advisory_route_plus_nonblocking_correction",
      "include": [
        "AGENTS.md",
        "integrations/workbuddy-python-runtime/workbuddy_harness/__init__.py",
        "integrations/workbuddy-python-runtime/workbuddy_harness/agent_loop_contract.py",
        "integrations/workbuddy-python-runtime/workbuddy_harness/gates.py",
        "integrations/workbuddy-python-runtime/workbuddy_harness/hook_runner.py",
        "integrations/workbuddy-python-runtime/workbuddy_harness/policy.py",
        "integrations/workbuddy-python-runtime/scripts/workbuddy-hook.cmd",
        "integrations/workbuddy-python-runtime/scripts/workbuddy-hook.sh",
        "skills/embedded-harness/behavior_correction_hook.py",
        "skills/embedded-harness/behavior_correction_profiles.json",
        "skills/embedded-harness/execution_feedback.py",
        "skills/embedded-harness/python_inline_write_analysis.py",
        "skills/embedded-harness/embedded_harness_policy.json"
      ],
      "host_blocking": false,
      "stateful_authorization": false,
      "registered_hooks": [
        "UserPromptSubmit"
      ],
      "optional_hooks": [
        "PreToolUse"
      ],
      "pretool_activation": "manual_after_host_protocol_verification",
      "workbuddy_protocol_status": "host_version_unverified",
      "output_contract": "advisory_by_default_optional_codex_allow_updated_input",
      "advisory_capabilities": [
        "memory_mode",
        "memory_source_hints",
        "external_need",
        "claim_risk_route_field",
        "feedback_loop_profile",
        "skill_lifecycle_profile",
        "tool_surface_need",
        "first_principles_profile",
        "skill_audit_profile",
        "human_confirmation_need_without_authority"
      ],
      "boundary": "Risk and confirmation fields are model-facing context only. Native host policy and governing instructions retain execution authority. Optional allow + updatedInput output must not be registered until the target WorkBuddy version's permission semantics are verified."
    },
    "workbuddy-loop-integration-sdk": {
      "required_predeployment_read": "docs/agent-deployment-map.md",
      "description": "Files needed by a host team that will call the Python decision layer and consume cbh.workbuddy_agent_loop_contract.v1 inside its Agent Loop.",
      "runtime_mode": "host_loop_integration_required",
      "include": [
        "AGENTS.md",
        "integrations/workbuddy-python-runtime/workbuddy_harness/__init__.py",
        "integrations/workbuddy-python-runtime/workbuddy_harness/agent_loop_contract.py",
        "integrations/workbuddy-python-runtime/workbuddy_harness/gates.py",
        "integrations/workbuddy-python-runtime/workbuddy_harness/hook_runner.py",
        "integrations/workbuddy-python-runtime/workbuddy_harness/policy.py",
        "integrations/workbuddy-python-runtime/scripts/workbuddy-hook.cmd",
        "integrations/workbuddy-python-runtime/scripts/workbuddy-hook.sh",
        "skills/embedded-harness/behavior_correction_gate.py",
        "skills/embedded-harness/behavior_correction_hook.py",
        "skills/embedded-harness/behavior_correction_profiles.json",
        "skills/embedded-harness/execution_feedback.py",
        "skills/embedded-harness/python_inline_write_analysis.py",
        "skills/embedded-harness/embedded_harness_policy.json",
        "skills/embedded-harness/harness_action_consumer.py",
        "templates/adapter-contract/compatibility.manifest.json"
      ],
      "host_blocking": false,
      "stateful_authorization": false,
      "pretool_activation": "manual_after_host_protocol_verification",
      "workbuddy_protocol_status": "host_version_unverified",
      "output_contract": "model_context_actions_plus_optional_codex_allow_updated_input",
      "required_host_work": [
        "call build_agent_loop_contract after intake routing",
        "feed selected memory context to the model agent before planning",
        "execute each returned action in the matching host-owned surface",
        "record a host-owned consumption receipt",
        "validate the receipt before claiming full loop integration"
      ]
    },
    "codex-local-minimal": {
      "required_predeployment_read": "docs/agent-deployment-map.md",
      "description": "Codex local instruction and PowerShell runtime files without research papers, articles, examples, or development tests.",
      "runtime_mode": "instruction_plus_selective_scripts",
      "include": [
        "AGENTS.md",
        "skills/embedded-harness/embedded_harness_policy.json",
        "skills/embedded-harness/behavior_correction_gate.py",
        "skills/embedded-harness/behavior_correction_hook.py",
        "skills/embedded-harness/behavior_correction_profiles.json",
        "skills/embedded-harness/behavior_correction_source_map.md",
        "skills/embedded-harness/execution_feedback.py",
        "skills/embedded-harness/harness_action_consumer.py",
        "skills/embedded-harness/harness_claim_schema_verifier.ps1",
        "skills/embedded-harness/harness_external_research_gate.ps1",
        "skills/embedded-harness/harness_intake_router.ps1",
        "skills/embedded-harness/harness_memory_isolation_gate.ps1",
        "skills/embedded-harness/python_inline_write_analysis.py",
        "skills/embedded-harness/validate_policy.ps1"
      ],
      "host_blocking": false,
      "boundary": "Direct scripts are advisory. The optional behavior hook may only return a verified current-input rewrite and never grants execution authority."
    }
  },
  "excluded_by_default": [
    "docs/**",
    "tests/**",
    "**/tests/**",
    "docs/articles/**",
    "**/*.pdf",
    "**/*.pptx",
    "**/*.docx",
    "CHANGELOG.md",
    "CITATION.cff",
    "paper/**",
    "research/**"
  ]
}
